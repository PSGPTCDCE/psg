import numpy as np 
import pandas as pd
data=pd.read_csv('1.csv')
print("dataset\n",data)
attri=np.array(data)[:,:-1]
tgt=np.array(data)[:,-1]
print("attribute:\n",attri)
print("tgt\n",tgt)

def train(a,t):
    for i,val in enumerate(t):
        if val=='yes':
            sph=a[i].copy()
            break
    for i,val in enumerate(a):
        if t[i]=='yes':
            for x in range(len(sph)):
                if t[x]!=sph[x]:
                    sph[x]='?'
                    return sph
fh=train(attri,tgt)
print('final hypothesis\n',fh)

