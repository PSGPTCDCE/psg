import pandas as pd 
import numpy as np 
data=pd.read_csv('1.csv')
print("dataset\n",data)
attri=np.array(data)[:,:-1]
tgt=np.array(data)[:,-1]
print("attribute:\n",attri)
print("tgt:\n",tgt)
sph=attri[0].copy()
gh=["?" for i in range(len(sph))]
print("sph:\n",sph)
print("gh:\n",gh)

for i,val in enumerate(attri):
    if tgt[i]=='yes':
        for x in range(len(sph)):
            if val[x]!=sph[x]:
                sph[x]="?"
                gh[x]="?"
    if tgt[i]=='no':
         for x in range(len(sph)):
             if val[x]!=sph[x]:
                 gh[x]=sph[x]
             else:
                 gh[x]='?'
print("final gh:\n",gh)
print("final shp:\n",sph)

