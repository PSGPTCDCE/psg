import pandas as pd
from efficient_apriori import apriori
data=pd.read_csv('3.csv',names=['name'],header=None)
print("dataset:\n",data)

trans=[i.split(',') for i in data['name']]
sets,rules=apriori(trans,min_support=.3,min_confidence=.5)
print("frequency items:\n")
for size,i in sets.items():
    for itemset,sup in i.items():
        print(f' items:{','.join(itemset):<25} support:{sup:<25.2f}')
print("association rules:\n")
print(f"{'antecedent':<25}{'concequent':<25}{'supp':<25}{'confidence':<25}{'lift':<25}")
for i in rules:
    print(f'{','.join(i.lhs):<25}{','.join(i.rhs):<25}{i.support:<25.2f}{i.confidence:<25.2f}{i.lift:<25.2f}')

